  "type": "module",
  "imports": {
    "#*": "./src/*",
    "#package.json": "./package.json"
  },
  "scripts": {
    "dev": "node ./src/index.ts",
    "test": "bun vitest --run",
    "format": "oxfmt --config='oxfmt.config.ts' --write",
