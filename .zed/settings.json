{
  "file_types": {
    "ini": [
      ".npmrc"
    ],
    "env": [
      ".env",
      ".env.*"
    ]
  },
  "hidden_files": [
    "**/.wrangler",
    "**/.agents"
  ],
  "file_scan_exclusions": [
    ".git",
    "**/.vscode",
    "**/.agents",
    "**/.wrangler",
    "**/.pi",
    "**/.crush",
    "**/.claude"
  ],
  "lsp": {
    "oxlint": {
      "initialization_options": {
        "settings": {
          "configPath": "oxlint.config.ts",
          "run": "onType",
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "typeAware": true,
          "unusedDisableDirectives": "deny"
        }
      }
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "fmt.configPath": "oxfmt.config.ts",
          "run": "onSave"
        }
      }
    }
  },
  "languages": {
    "MDX": {
      "language_servers": [
        "typescript-language-server",
        "oxfmt",
        "oxlint"
      ],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "Markdown": {
      "language_servers": [
        "typescript-language-server",
        "oxfmt",
        "oxlint",
        "markdown-oxide"
      ],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSON": {
      "format_on_save": "on",
      "language_servers": [
        "json-language-server",
        "oxfmt",
        "oxlint"
      ],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSONC": {
      "format_on_save": "on",
      "language_servers": [
        "json-language-server",
        "oxfmt",
        "oxlint"
      ],
      "prettier": {
        "allowed": false
      },
      "formatter": [
